{
  "mcpServers": {
    "GPT Image 2 API": {
      "command": "npx",
      "args": [
        "-y",
        "gpt-image-2-mcp"
      ],
      "env": {
        "GPT_IMAGE_BACKEND": "api",
        "OPENAI_API_KEY": "YOUR_OPENAI_API_KEY"
      }
    },
    "GPT Image 2 ChatGPT Web": {
      "command": "npx",
      "args": [
        "-y",
        "gpt-image-2-mcp"
      ],
      "env": {
        "GPT_IMAGE_BACKEND": "chatgpt-web"
      }
    }
  }
}
