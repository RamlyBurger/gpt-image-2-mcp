    "README.md",
    "mcp_config.example.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^6.34.0",
    "patchright": "^1.59.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
