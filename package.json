{
  "name": "gpt-image-2-mcp",
  "version": "0.2.0",
  "description": "MCP server for GPT Image 2 with selectable OpenAI API and ChatGPT web backends.",
  "type": "module",
  "bin": {
    "gpt-image-2-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
